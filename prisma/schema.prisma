generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  GOING
  FINISHED
}

model User {
  // id aligns with auth.users.id — set by the auth trigger, not auto-generated
  id          String   @id
  email       String   @unique
  nickname    String   @default("")
  emoji       String   @default("⚽")
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  memberships GroupMember[]
  bets        UserBet[]
  details       Json?
}

model Competition {
  id                String    @id @default(uuid())
  name              String    @unique
  createdAt         DateTime  @default(now())
  endDate           DateTime?
  matches           Match[]
  groups            Group[]
  // Many-to-many join rows. A Match can be referenced by many
  // Competitions (e.g., a match from the Champions League can also
  // appear in a "Best of 2026" custom tournament). The Match's
  // primary vendor parent is still Match.competitionId (one-to-many) —
  // this list is for cross-tournament references. See CompetitionMatch.
  customMatchLinks  CompetitionMatch[]
  // External provider linkage. NULL for competitions seeded by hand
  // (e.g., the JSON-paste hydration terminal). Non-NULL means the
  // cron will auto-sync this competition from the provider.
  externalSource    String?
  externalLeagueId  String?
  externalSeason    Int?
  lastSyncedAt      DateTime?
  // Soft delete: NULL = active, non-NULL = deleted at this time. The
  // data is preserved so an admin can un-delete by clearing the
  // column. The PATCH endpoint at
  // app/api/v1/admin/competitions/[id]/route.ts writes to this column;
  // every competition read path must filter `deletedAt: null` to
  // exclude deleted tournaments from listings.
  deletedAt         DateTime?
  // Free-form JSON. Future use cases: tournament branding, custom
  // rule overrides, etc. Consumers must defensively validate.
  details           Json?
}

model Match {
  id              String      @id @default(uuid())
  competitionId   String
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  apiMatchId      String      @unique
  homeTeam        String
  awayTeam        String
  kickoffTime     DateTime
  stage           String
  status          MatchStatus @default(SCHEDULED)
  markets         BetMarket[]
  // Many-to-many join rows. See CompetitionMatch — this is the
  // inverse of Competition.customMatchLinks. The Match's primary
  // vendor parent is still competitionId (one-to-many); this list is
  // for cross-tournament references only.
  customLinks     CompetitionMatch[]
  // Final score, set when the external provider reports the fixture as
  // finished. NULL while the match is still pending or live. Read by
  // the auto-settle pass to populate correctAnswer on EXACT_SCORE.
  homeScore       Int?
  awayScore       Int?
  // Half-time goals. NULL until the match has reached HT in the
  // external provider. Drives the HT/FT bet market.
  homeHtGoals     Int?
  awayHtGoals     Int?
  // Penalty shootout result. NULL unless the match went to a shootout
  // (knockout ties after extra time). Drives the Penalty Shootout
  // bet market on knockout-stage matches.
  homePenalties   Int?
  awayPenalties   Int?
  // Raw status string from the provider (NS, 1H, HT, 2H, FT, AET, PEN).
  // Useful for debugging and for not-yet-implemented live states.
  externalStatus  String?
  // Team crest URLs. Populated by the football-data.org ingest pipeline
  // (from `homeTeam.crest` / `awayTeam.crest`) and by the manual JSON
  // hydration terminal. NULL when the provider has no crest or the JSON
  // omitted one — the UI falls back to a team-initial circle in that case.
  homeCrest       String?
  awayCrest       String?
  // Timestamp of the most recent successful user-driven refresh
  // (see app/api/v1/matches/[id]/refresh/route.ts). The 5-min
  // per-match rate limit is enforced against this column. NULL means
  // "never refreshed" (i.e. only the cron / sync has touched this
  // match). The cron path does NOT update this column — the cron is
  // its own cadence and the user-driven rate limit is independent.
  scoreLastSyncedAt DateTime?
  // Free-form JSON column. Phase 11+ uses it for:
  //   - scoringOverride: { <STAGE>: Partial<StageScoring> } — per-match
  //     override on top of the group's scoring config (see
  //     lib/services/scoring/resolve-config.ts).
  //   - any future per-match metadata (stage notes, admin tags, etc.)
  // The shape is intentionally open. Consumers must defensively
  // validate the contents.
  details         Json?

  @@index([competitionId])
  @@index([kickoffTime])
  @@index([status])
}

// Many-to-many join table for custom tournaments. A Match can be
// referenced by many Competitions (e.g., a match in the Champions
// League can also be added to a "Best of 2026" custom tournament).
// The Match's primary vendor parent is still Match.competitionId
// (one-to-many) — the join table is for cross-tournament references.
model CompetitionMatch {
  matchId        String
  competitionId  String
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  competition    Competition  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  addedAt        DateTime     @default(now())

  @@id([matchId, competitionId])
  @@index([competitionId])
  @@index([matchId])
}

model Group {
  id            String        @id @default(uuid())
  competitionId String
  competition   Competition   @relation(fields: [competitionId], references: [id])
  name          String
  inviteCode    String        @unique
  scoringConfig Json
  createdAt     DateTime      @default(now())
  members       GroupMember[]
  bets          UserBet[]
  // Free-form JSON. Future use: per-group custom metadata that
  // doesn't belong in scoringConfig. Consumers must defensively
  // validate.
  details       Json?

  @@index([competitionId])
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  details       Json?
  @@unique([userId, groupId])
  @@index([groupId])
}

model BetMarket {
  id            String    @id @default(uuid())
  matchId       String?
  match         Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type          String
  title         String
  options       Json?
  correctAnswer String?
  isSettled     Boolean   @default(false)
  userBets      UserBet[]
  // Free-form JSON. Future use: per-market metadata (custom
  // labels, scoring rule overrides, etc.). Consumers must
  // defensively validate.
  details       Json?

  @@unique([matchId, type, title])
  @@index([matchId])
  @@index([isSettled])
}

model UserBet {
  id             String    @id @default(uuid())
  userId         String
  groupId        String
  marketId       String
  predictedValue String
  pointsAwarded  Int?
  /// Anti-snooping flag. False until the underlying match becomes
  /// locked (5 min before kickoff) or finishes. Flipped lazily by
  /// getGroupFeed via revealBetsForLockedMatches(). Query filter:
  /// isRevealed = true to show non-owner viewers.
  isRevealed     Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group          Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  market         BetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  details       Json?
  @@unique([userId, groupId, marketId])
  @@index([groupId])
  @@index([marketId])
  @@index([pointsAwarded])
  @@index([isRevealed])
}


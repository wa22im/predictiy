generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  FINISHED
}

model User {
  // id aligns with auth.users.id — set by the auth trigger, not auto-generated
  id          String   @id
  email       String   @unique
  nickname    String   @default("")
  emoji       String   @default("⚽")
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  memberships GroupMember[]
  bets        UserBet[]
}

model Competition {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  matches   Match[]
  groups    Group[]
}

model Match {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  apiMatchId    String      @unique
  homeTeam      String
  awayTeam      String
  kickoffTime   DateTime
  stage         String
  status        MatchStatus @default(SCHEDULED)
  markets       BetMarket[]

  @@index([competitionId])
  @@index([kickoffTime])
  @@index([status])
}

model Group {
  id            String        @id @default(uuid())
  competitionId String
  competition   Competition   @relation(fields: [competitionId], references: [id])
  name          String
  inviteCode    String        @unique
  scoringConfig Json
  createdAt     DateTime      @default(now())
  members       GroupMember[]
  bets          UserBet[]

  @@index([competitionId])
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model BetMarket {
  id            String    @id @default(uuid())
  matchId       String?
  match         Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type          String
  title         String
  options       Json?
  correctAnswer String?
  isSettled     Boolean   @default(false)
  userBets      UserBet[]

  @@unique([matchId, type, title])
  @@index([matchId])
  @@index([isSettled])
}

model UserBet {
  id             String    @id @default(uuid())
  userId         String
  groupId        String
  marketId       String
  predictedValue String
  pointsAwarded  Int?
  isRevealed     Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group          Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  market         BetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, marketId])
  @@index([groupId])
  @@index([marketId])
  @@index([pointsAwarded])
  @@index([isRevealed])
}


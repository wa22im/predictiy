generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  GOING
  FINISHED
}

model User {
  // id aligns with auth.users.id — set by the auth trigger, not auto-generated
  id          String   @id
  email       String   @unique
  nickname    String   @default("")
  emoji       String   @default("⚽")
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  memberships GroupMember[]
  bets        UserBet[]
}

model Competition {
  id                String    @id @default(uuid())
  name              String    @unique
  createdAt         DateTime  @default(now())
  matches           Match[]
  groups            Group[]
  // External provider linkage. NULL for competitions seeded by hand
  // (e.g., the JSON-paste hydration terminal). Non-NULL means the
  // cron will auto-sync this competition from the provider.
  externalSource    String?
  externalLeagueId  String?
  externalSeason    Int?
  lastSyncedAt      DateTime?
}

model Match {
  id              String      @id @default(uuid())
  competitionId   String
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  apiMatchId      String      @unique
  homeTeam        String
  awayTeam        String
  kickoffTime     DateTime
  stage           String
  status          MatchStatus @default(SCHEDULED)
  markets         BetMarket[]
  // Final score, set when the external provider reports the fixture as
  // finished. NULL while the match is still pending or live. Read by
  // the auto-settle pass to populate correctAnswer on EXACT_SCORE.
  homeScore       Int?
  awayScore       Int?
  // Half-time goals. NULL until the match has reached HT in the
  // external provider. Drives the HT/FT bet market.
  homeHtGoals     Int?
  awayHtGoals     Int?
  // Penalty shootout result. NULL unless the match went to a shootout
  // (knockout ties after extra time). Drives the Penalty Shootout
  // bet market on knockout-stage matches.
  homePenalties   Int?
  awayPenalties   Int?
  // Raw status string from the provider (NS, 1H, HT, 2H, FT, AET, PEN).
  // Useful for debugging and for not-yet-implemented live states.
  externalStatus  String?

  @@index([competitionId])
  @@index([kickoffTime])
  @@index([status])
}

model Group {
  id            String        @id @default(uuid())
  competitionId String
  competition   Competition   @relation(fields: [competitionId], references: [id])
  name          String
  inviteCode    String        @unique
  scoringConfig Json
  createdAt     DateTime      @default(now())
  members       GroupMember[]
  bets          UserBet[]

  @@index([competitionId])
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model BetMarket {
  id            String    @id @default(uuid())
  matchId       String?
  match         Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type          String
  title         String
  options       Json?
  correctAnswer String?
  isSettled     Boolean   @default(false)
  userBets      UserBet[]

  @@unique([matchId, type, title])
  @@index([matchId])
  @@index([isSettled])
}

model UserBet {
  id             String    @id @default(uuid())
  userId         String
  groupId        String
  marketId       String
  predictedValue String
  pointsAwarded  Int?
  /// When this bet becomes visible to other group members. Set to
  /// Match.kickoffTime at save time. Query filter: availableFrom <= now.
  availableFrom  DateTime
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group          Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  market         BetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, marketId])
  @@index([groupId])
  @@index([marketId])
  @@index([pointsAwarded])
  @@index([availableFrom])
}

